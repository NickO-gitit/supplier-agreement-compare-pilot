# Local dev option A: call a server-side proxy (recommended for Azure hosting)
VITE_RISK_API_URL=/api/analyze-risk
VITE_RISK_FOLLOWUP_API_URL=/api/risk-followup
VITE_GROUPING_REVIEW_API_URL=/api/review-grouping

# Local dev option B: direct OpenAI API from browser (not recommended for production)
VITE_OPENAI_API_KEY=sk-your-api-key-here
VITE_OPENAI_MODEL=gpt-4.1-mini

# Local dev option C: direct Azure OpenAI from browser (not recommended for production)
VITE_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
VITE_AZURE_OPENAI_KEY=your-azure-api-key
VITE_AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# Container/server runtime (used by Docker + Azure Container Apps)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_KEY=your-azure-api-key
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-10-21
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
