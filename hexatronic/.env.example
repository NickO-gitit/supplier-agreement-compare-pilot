# ============================================================
# .env.example  –  Copy to .env and fill in real values.
# The deploy.sh script reads this file and maps values to
# Bicep parameters automatically.
# NEVER commit .env to source control!
# ============================================================

# ── Azure ────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_RESOURCE_GROUP=my-resource-group
AZURE_LOCATION=swedencentral

# ── App identity ─────────────────────────────────────────────
ENVIRONMENT_NAME=myapp-prod

# ── Container Image ──────────────────────────────────────────
CONTAINER_IMAGE=myappprodacr.azurecr.io/myapp:latest

# ── Database (leave blank to auto-deploy SQL) ─────────────────
# If you have an existing DB, paste the connection string here.
# Script will detect and skip SQL deployment automatically.
DATABASE_CONNECTION_STRING=

# ── New SQL (only used if DATABASE_CONNECTION_STRING is empty) ─
SQL_ADMIN_LOGIN=sqladmin
SQL_DATABASE_NAME=appdb

# ── Microsoft Foundry ─────────────────────────────────────────
FOUNDRY_ENDPOINT=https://your-foundry.openai.azure.com/
FOUNDRY_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
FOUNDRY_API_KEY=
FOUNDRY_DEPLOYMENT=gpt-4.1-mini
FOUNDRY_API_VERSION=2024-10-21

# ── Azure OpenAI (optional fallback) ─────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_KEY=

# ── OpenAI (optional fallback) ────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
